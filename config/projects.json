{
  "projects_root": "mounted-projects",
  "projects": [
    {
      "name": "deepblue-documents-kube",
      "stack": "k8s-gitops",
      "relative_path": "deepblue-documents-kube",
      "commands": {
        "validate": "tk show environments/clusters/deepblue-documents --dangerous-allow-redirect | head -n 30",
        "diff": "tk diff environments/clusters/deepblue-documents"
      }
    },
    {
      "name": "dor-depot",
      "stack": "java-spring",
      "relative_path": "dor-depot",
      "commands": {
        "test": "./gradlew test",
        "dev": "./gradlew bootRun"
      }
    },
    {
      "name": "dor-react-app",
      "stack": "react-vite",
      "relative_path": "dor-react-app",
      "commands": {
        "test": "npm run test -- --run",
        "lint": "npm run lint",
        "dev": "npm run dev"
      }
    },
    {
      "name": "dspace-containerization",
      "stack": "dspace-docker",
      "relative_path": "dspace-containerization",
      "commands": {
        "test": "make test",
        "up": "make up"
      }
    },
    {
      "name": "findingaids-argocd",
      "stack": "k8s-gitops",
      "relative_path": "findingaids-argocd",
      "commands": {
        "validate": "tk show environments/clusters/findingaids --dangerous-allow-redirect | head -n 30"
      }
    },
    {
      "name": "umich-arclight",
      "stack": "rails-arclight",
      "relative_path": "umich-arclight",
      "commands": {
        "test": "docker-compose exec -T app bundle exec rspec",
        "lint": "docker-compose exec -T app bundle exec rubocop"
      }
    }
  ]
}
