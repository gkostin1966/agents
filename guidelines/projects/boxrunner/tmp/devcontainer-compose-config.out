name: boxrunner
services:
  app:
    build:
      context: /Users/gkostin/GitHub/mlibrary/boxrunner
      dockerfile: .devcontainer/Dockerfile
    depends_on:
      redis:
        condition: service_healthy
        required: true
      solr:
        condition: service_healthy
        required: true
    environment:
      BUNDLE_APP_CONFIG: /rails/.bundle
      BUNDLE_DEPLOYMENT: "0"
      BUNDLE_DISABLE_SHARED_GEMS: "true"
      BUNDLE_PATH: /rails/vendor/bundle
      BUNDLE_WITHOUT: ""
      RAILS_ENV: development
      REDIS_URL: redis://redis:6379/0
      SOLR_URL: http://solr:8983/solr/blacklight-collection
    networks:
      default: null
    ports:
      - mode: ingress
        target: 3000
        published: "3000"
        protocol: tcp
  redis:
    command:
      - redis-server
      - --appendonly
      - "yes"
    healthcheck:
      test:
        - CMD
        - redis-cli
        - ping
      timeout: 10s
      interval: 30s
      retries: 5
      start_period: 30s
    image: redis:7
    networks:
      default: null
    ports:
      - mode: ingress
        target: 6379
        published: "6379"
        protocol: tcp
    volumes:
      - type: volume
        source: redis-data
        target: /data
        volume: {}
  resque:
    build:
      context: /Users/gkostin/GitHub/mlibrary/boxrunner
      dockerfile: Dockerfile
    command:
      - bundle
      - exec
      - rake
      - environment
      - resque:work
    depends_on:
      redis:
        condition: service_healthy
        required: true
    environment:
      QUEUE: '*'
      RAILS_MASTER_KEY: 68208d3f29f4babd412f6abb067d8a2e
      REDIS_URL: redis://redis:6379/0
      SOLR_URL: http://solr:8983/solr/blacklight-collection
    networks:
      default: null
  resque-web:
    build:
      context: /Users/gkostin/GitHub/mlibrary/boxrunner
      dockerfile: Dockerfile
    command:
      - bundle
      - exec
      - rackup
      - -o
      - 0.0.0.0
      - -p
      - "5678"
      - config/resque_web.ru
    depends_on:
      redis:
        condition: service_healthy
        required: true
    environment:
      REDIS_URL: redis://redis:6379/0
      RESQUE_NAMESPACE: resque:boxrunner
    networks:
      default: null
    ports:
      - mode: ingress
        target: 5678
        published: "5678"
        protocol: tcp
  solr:
    command:
      - solr-foreground
    depends_on:
      zookeeper:
        condition: service_healthy
        required: true
    environment:
      SOLR_HEAP: 1024m
      SOLR_JAVA_MEM: -Xms1024m -Xmx1024m
      ZK_HOST: zookeeper:2181
    healthcheck:
      test:
        - CMD-SHELL
        - curl -s -f 'http://localhost:8983/solr/admin/collections?action=CLUSTERSTATUS'
      timeout: 10s
      interval: 30s
      retries: 5
      start_period: 30s
    image: solr:9.7
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8983
        published: "8983"
        protocol: tcp
    volumes:
      - type: volume
        source: solr-data
        target: /var/solr
        volume: {}
      - type: bind
        source: /Users/gkostin/GitHub/mlibrary/boxrunner/solr/conf
        target: /opt/solr/conf
        bind: {}
  zookeeper:
    environment:
      ZOO_MY_ID: "1"
      ZOO_SERVERS: server.1=0.0.0.0:2888:3888;2181
    healthcheck:
      test:
        - CMD
        - nc
        - -z
        - -w
        - "2"
        - localhost
        - "2181"
      timeout: 10s
      interval: 30s
      retries: 5
      start_period: 30s
    image: zookeeper
    networks:
      default: null
    ports:
      - mode: ingress
        target: 2181
        published: "2181"
        protocol: tcp
networks:
  default:
    name: boxrunner_default
volumes:
  redis-data:
    name: boxrunner_redis-data
  solr-data:
    name: boxrunner_solr-data
